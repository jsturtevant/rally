{
  "name": "squad-rally",
  "version": "0.1.0",
  "description": "CLI tool that dispatches Squad teams to GitHub issues and PR reviews via git worktrees",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsturtevant/rally.git"
  },
  "bin": {
    "rally": "./bin/rally.js"
  },
  "scripts": {
    "test": "GIT_TERMINAL_PROMPT=0 node test/build-jsx.mjs && node --test ./test/*.test.js && node --test --test-force-exit ./test/ui/*.test.js",
    "test:e2e": "GIT_TERMINAL_PROMPT=0 node test/build-jsx.mjs && node --test ./test/e2e/*.test.js",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "ink-table": "^3.1.0",
    "js-yaml": "^4.0.0",
    "ora": "^8.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "ink-testing-library": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
